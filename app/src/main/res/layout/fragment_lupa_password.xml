<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageView
            android:id="@+id/btnBackForgot"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_arrow_back_modern"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#0F172A" />

        <FrameLayout
            android:id="@+id/ivForgotIconFrame"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_rounded_blue_light"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBackForgot">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock_padat"
                app:tint="#2563EB" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvForgotTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Lupa Sandi?"
            android:textColor="#0F172A"
            android:textSize="32sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivForgotIconFrame" />

        <TextView
            android:id="@+id/tvForgotSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="6dp"
            android:text="Jangan khawatir! Masukkan email kampus yang terdaftar untuk menerima instruksi pemulihan kata sandi."
            android:textColor="#64748B"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tvForgotTitle" />

        <TextView
            android:id="@+id/labelForgotEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/inter_bold"
            android:letterSpacing="0.05"
            android:text="EMAIL KAMPUS / NIM"
            android:textColor="#94A3B8"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvForgotSubtitle" />

        <FrameLayout
            android:id="@+id/flInputForgotEmail"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_modern"
            app:layout_constraintTop_toBottomOf="@id/labelForgotEmail">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_mail_outline"
                app:tint="#94A3B8" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etForgotEmail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/transparent"
                android:fontFamily="@font/inter_regular"
                android:hint="Contoh: nim@student.umkt.ac.id"
                android:inputType="textEmailAddress"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:textColor="#0F172A"
                android:textColorHint="#CBD5E1"
                android:textSize="15sp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/infoBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_info_slate"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/flInputForgotEmail">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_info_modern" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="4dp"
                android:text="Tautan untuk mereset kata sandi akan dikirimkan ke kotak masuk atau folder spam email Anda dalam beberapa menit."
                android:textColor="#64748B"
                android:textSize="12.5sp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/btnKirimReset"
            app:layout_constraintTop_toBottomOf="@id/infoBox"
            app:layout_constraintVertical_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKirimReset"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#2563EB"
            android:fontFamily="@font/inter_bold"
            android:text="Kirim Tautan Reset"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_send_modern"
            app:iconGravity="textEnd"
            app:iconPadding="12dp"
            app:iconSize="20dp"
            app:iconTint="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/infoBox"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>