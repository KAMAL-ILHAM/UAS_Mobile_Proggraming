<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvMajor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TEKNIK INFORMATIKA"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:fontFamily="@font/inter_bold" />
                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Halo, Kamal Ilham !"
                        android:textColor="#0F172A"
                        android:textSize="26sp"
                        android:fontFamily="@font/inter_extrabold" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">
                    <androidx.cardview.widget.CardView
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        app:cardBackgroundColor="#2563EB"
                        app:cardCornerRadius="26dp"
                        app:cardElevation="0dp">
                        <TextView
                            android:id="@+id/tvInitials"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="KI"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:fontFamily="@font/inter_bold" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardReport"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_gradient_blue_card">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:paddingStart="24dp"
                        android:paddingEnd="120dp">

                        <TextView
                            android:id="@+id/tvReportStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● SEDANG DIPROSES"
                            android:textColor="#FBBC05"
                            android:textSize="10sp"
                            android:fontFamily="@font/inter_bold"
                            android:letterSpacing="0.05" />


                        <TextView
                            android:id="@+id/tvReportTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="AC Lab Software"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:fontFamily="@font/inter_extrabold" />

                        <TextView
                            android:id="@+id/tvReportLocation" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Gedung F Lt. 1, UMKT"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:alpha="0.9"
                            android:drawablePadding="6dp"
                            app:drawableStartCompat="@drawable/ic_location_solid"
                            app:drawableTint="@color/white" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="150dp"
                        android:layout_height="150dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_centerInParent="true"
                            android:src="@drawable/bg_circle_outline" />

                        <RelativeLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_centerInParent="true"
                            android:background="@drawable/bg_btn_arrow">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_centerInParent="true"
                                android:src="@drawable/ic_arrow_right" />
                        </RelativeLayout>
                    </RelativeLayout>

                </RelativeLayout>


            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBuatLaporan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardBackgroundColor="#2563EB"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_camera_plus" />
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_extrabold"
                            android:text="Buat Laporan Baru"
                            android:textColor="#0F172A"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_medium"
                            android:lineSpacingExtra="2dp"
                            android:text="Foto kerusakan langsung di lokasi untuk pelaporan instan."
                            android:textColor="#64748B"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="4dp"
                        android:src="@drawable/ic_chevron_right" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Kategori Fasilitas"
                android:fontFamily="@font/inter_bold"
                android:textColor="#0F172A" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <include android:id="@+id/cat1" layout="@layout/item_category" />
                    <include android:id="@+id/cat2" layout="@layout/item_category" />
                    <include android:id="@+id/cat3" layout="@layout/item_category" />
                    <include android:id="@+id/cat4" layout="@layout/item_category" />
                    <include android:id="@+id/cat5" layout="@layout/item_category" />
                    <include android:id="@+id/cat6" layout="@layout/item_category" />
                </LinearLayout>
            </HorizontalScrollView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/inter_extrabold"
                    android:text="Riwayat Anda"
                    android:textColor="#0F172A"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/btnSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="@font/inter_bold"
                    android:text="LIHAT SEMUA"
                    android:textColor="#2563EB"
                    android:textSize="12sp"
                    android:letterSpacing="0.05" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/containerRiwayat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="40dp"> <include layout="@layout/item_riwayat" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/white"
        android:elevation="16dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/navBeranda"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="22dp" android:src="@drawable/ic_beranda" app:tint="#2563EB" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beranda" android:textColor="#2563EB" android:textSize="10sp" android:fontFamily="@font/inter_bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navRiwayat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_riwayat" app:tint="#94A3B8" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Riwayat" android:textColor="#94A3B8" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotifikasi"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_notifikasi" app:tint="#94A3B8" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Notifikasi" android:textColor="#94A3B8" android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navProfil"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profil"
                    app:tint="#94A3B8" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/badgeProfilRedDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:layout_gravity="top|end"
                    app:cardBackgroundColor="#EF4444"
                    app:cardCornerRadius="5dp"
                    app:cardElevation="0dp"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profil"
                android:textColor="#94A3B8"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>