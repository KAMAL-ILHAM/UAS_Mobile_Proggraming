<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCenterContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomContainer"
        app:layout_constraintVertical_bias="0.4"> <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutIllustration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:id="@+id/circleOuter"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/bg_circle_white"
            android:elevation="16dp"
            android:outlineAmbientShadowColor="#94A3B8"
            android:outlineSpotShadowColor="#94A3B8"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="1.0">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_green">

            </FrameLayout>

            <FrameLayout
                android:id="@+id/badgeSparkle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_badge_yellow_soft"
                android:elevation="8dp"
                android:rotation="15">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_sparkle_orange" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:elevation="30dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_sparkle_orange" />

            </FrameLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_bold_white" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvTitleSuccess"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Laporan Terkirim!"
            android:textColor="#0F172A"
            android:textSize="26sp"
            app:layout_constraintTop_toBottomOf="@id/layoutIllustration"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTicketBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_ticket_badge"
            android:fontFamily="@font/inter_bold"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:text="TIKET: #EIO-8822"
            android:textColor="#2563EB"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            app:layout_constraintTop_toBottomOf="@id/tvTitleSuccess"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/inter_medium"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:text="Laporan Anda telah berhasil masuk ke sistem kami. Mohon tunggu tim Admin memvalidasi laporan Anda dalam waktu dekat."
            android:textColor="#64748B"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTicketBadge"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/bottomContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLacakStatus"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lacak Status Laporan"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:fontFamily="@font/inter_bold"
            app:backgroundTint="#2563EB"
            app:cornerRadius="16dp"
            app:elevation="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnKembaliBeranda"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Kembali ke Beranda"
            android:textAllCaps="false"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:fontFamily="@font/inter_bold"
            app:strokeColor="#CBD5E1"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>