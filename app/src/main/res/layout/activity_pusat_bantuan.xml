<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="4dp"
            android:src="@drawable/ic_arrow_back_modern"
            app:tint="#0F172A"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Pusat Bantuan"
            android:textColor="#0F172A"
            android:textSize="20sp" />
    </LinearLayout>

    <View
        android:id="@+id/dividerHeader"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        app:layout_constraintTop_toBottomOf="@id/headerLayout" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        app:layout_constraintTop_toBottomOf="@id/dividerHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/layoutMainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search_gray" />

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="12dp"
                    android:background="@null"
                    android:fontFamily="@font/inter_medium"
                    android:hint="Cari topik bantuan..."
                    android:textColor="#0F172A"
                    android:textColorHint="#94A3B8"
                    android:textSize="14sp"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardChatAdmin"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_help"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_blue_light"
                        app:backgroundTint="#EEF2FF">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_chat_bubble_blue" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="Chat Admin"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Online 08:00 - 16:00"
                        android:textColor="#64748B"
                        android:textSize="11sp" />
                </LinearLayout>

                <View android:layout_width="16dp" android:layout_height="match_parent" />

                <LinearLayout
                    android:id="@+id/cardBukuPanduan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_help"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_circle_blue_light"
                        app:backgroundTint="#FEF3C7"> <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_book_orange" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/inter_bold"
                        android:text="Buku Panduan"
                        android:textColor="#0F172A"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter_medium"
                        android:text="Cara lapor &amp; fitur PDF"
                        android:textColor="#64748B"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/inter_bold"
                android:text="PERTANYAAN SERING DIAJUKAN (FAQ)"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:letterSpacing="0.05" />

            <LinearLayout
                android:id="@+id/faqListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:clipChildren="false"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/faq1Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_faq_expanded"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/faq1Header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/ivArrow1"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="Berapa lama laporan diproses?"
                            android:textColor="#0F172A"
                            android:textSize="14sp" />
                        <ImageView
                            android:id="@+id/ivArrow1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_down_blue"
                            android:rotation="180"/> </RelativeLayout>
                    <TextView
                        android:id="@+id/tvAnswer1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="6dp"
                        android:text="Laporan akan divalidasi oleh Admin paling lambat 1×24 jam kerja. Setelah divalidasi, teknisi akan ditugaskan sesuai dengan tingkat urgensi dan ketersediaan."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:visibility="visible" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/faq2Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_faq_collapsed"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/faq2Header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/ivArrow2"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="Apakah saya bisa membatalkan laporan?"
                            android:textColor="#475569"
                            android:textSize="14sp" />
                        <ImageView
                            android:id="@+id/ivArrow2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_down_blue"
                            app:tint="#94A3B8"/>
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvAnswer2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="6dp"
                        android:text="Ya, Anda dapat membatalkan laporan yang berstatus 'Terkirim'. Jika status sudah 'Diproses', pembatalan harus melalui persetujuan Admin via Chat."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:visibility="gone" /> </LinearLayout>

                <LinearLayout
                    android:id="@+id/faq3Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_faq_collapsed"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/faq3Header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/ivArrow3"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="Mengapa saya tidak bisa upload foto dari galeri?"
                            android:textColor="#475569"
                            android:textSize="14sp" />
                        <ImageView
                            android:id="@+id/ivArrow3"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_down_blue"
                            app:tint="#94A3B8"/>
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvAnswer3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="6dp"
                        android:text="Untuk menghindari laporan palsu atau foto lama, sistem EIO mewajibkan pengambilan gambar kerusakan dilakukan secara real-time melalui kamera aplikasi."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/faq4Container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_faq_collapsed"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:id="@+id/faq4Header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toStartOf="@id/ivArrow4"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="Gagal login dengan NIM?"
                            android:textColor="#475569"
                            android:textSize="14sp" />
                        <ImageView
                            android:id="@+id/ivArrow4"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_down_blue"
                            app:tint="#94A3B8"/>
                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tvAnswer4"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter_regular"
                        android:lineSpacingExtra="6dp"
                        android:text="Pastikan Anda memasukkan NIM dengan benar (tanpa spasi). Jika password salah, silakan hubungi pusat layanan IT di gedung rektorat untuk reset password."
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>