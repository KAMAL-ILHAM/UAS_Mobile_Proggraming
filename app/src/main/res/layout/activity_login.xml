<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingTop="16dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back_modern"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />

        <FrameLayout
            android:id="@+id/ivLogoBackground"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_rounded_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBack">

            <ImageView
                android:id="@+id/ivLogoUser"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_logo_user"
                app:tint="@color/primary_blue" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Masuk ke Akun"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogoBackground" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="6dp"
            android:text="Validasi identitas sebagai mahasiswa aktif untuk mulai melaporkan fasilitas."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <TextView
            android:id="@+id/labelNim"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/inter_semibold"
            android:text="NOMOR INDUK MAHASISWA (NIM)"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

        <FrameLayout
            android:id="@+id/flInputNim"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_modern"
            app:layout_constraintTop_toBottomOf="@id/labelNim">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_user_outline"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvNimPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="48dp"
                android:fontFamily="@font/inter_regular"
                android:text="Contoh: 241110..."
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/transparent"
                android:inputType="number"
                android:paddingStart="48dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:backgroundTint="@color/transparent" />
        </FrameLayout>

        <TextView
            android:id="@+id/labelPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:fontFamily="@font/inter_semibold"
            android:text="KATA SANDI / PIN SIAKAD"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.05"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flInputNim" />

        <FrameLayout
            android:id="@+id/flInputPassword"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_modern"
            app:layout_constraintTop_toBottomOf="@id/labelPassword">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_lock_outline"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvPasswordPlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:layout_marginStart="48dp"
                android:fontFamily="@font/inter_regular"
                android:text="••••••••"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/ivPasswordVisibility"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_visibility"
                app:tint="@color/text_secondary"
                android:clickable="true"
                android:focusable="true"/>

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/transparent"
                android:inputType="textPassword"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:backgroundTint="@color/transparent" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvForgotPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter_semibold"
            android:text="Lupa kata sandi?"
            android:textColor="@color/primary_blue"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/flInputPassword" />

        <LinearLayout
            android:id="@+id/warningBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_warning"
            android:padding="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvForgotPassword">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="2dp"
                android:src="@drawable/ic_shield_modern"
                app:tint="@color/text_warning" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:fontFamily="@font/inter_regular"
                android:lineSpacingExtra="4dp"
                android:text="Sistem Anti-Spam: Laporan hanya dapat dibuat oleh akun tervalidasi. Penggunaan NIM orang lain dapat dikenakan sanksi akademik."
                android:textColor="@color/text_warning"
                android:textSize="12sp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/btnLogin"
            app:layout_constraintTop_toBottomOf="@id/warningBox"
            app:layout_constraintVertical_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:backgroundTint="@color/primary_blue"
            android:fontFamily="@font/inter_bold"
            android:text="Masuk Sistem"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_arrow_forward_small"
            app:iconGravity="end"
            app:iconPadding="10dp"
            app:iconSize="16dp"
            app:iconTint="@color/white"
            app:elevation="8dp"
            app:layout_constraintBottom_toTopOf="@id/llFooter"
            app:layout_constraintTop_toBottomOf="@id/warningBox"
            app:layout_constraintVertical_bias="1.0" />

        <LinearLayout
            android:id="@+id/llFooter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_regular"
                android:text="Belum Memiliki Akun? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Buat Akun"
                android:textColor="@color/primary_blue"
                android:textSize="14sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>