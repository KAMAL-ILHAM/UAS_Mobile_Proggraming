<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_50">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/fixedHeaderSection"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="#0F172A"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideHeaderTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_begin="48dp" />

        <FrameLayout
            android:id="@+id/btnBackDetail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_circle_dark_transparent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/guideHeaderTop">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back_modern" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvReportId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_outline_badge"
            android:fontFamily="@font/inter_bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:text="ID: EIO-8821"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/btnBackDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/guideHeaderTop" />

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="56dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="AC Ruang Lab Rusak &amp; Panas"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/badgeStatusDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_status_resolved"
            android:fontFamily="@font/inter_bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="SELESAI"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            app:layout_constraintBottom_toTopOf="@id/tvDetailTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDetailTanggal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:fontFamily="@font/inter_medium"
            android:text="15 Apr 2026"
            android:textColor="#CBD5E1"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/badgeStatusDetail"
            app:layout_constraintStart_toEndOf="@id/badgeStatusDetail"
            app:layout_constraintTop_toTopOf="@id/badgeStatusDetail" />

        <ImageView
            android:id="@+id/ivBigIcon"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:alpha="0.10"
            android:src="@drawable/ic_winding_air"
            app:layout_constraintBottom_toTopOf="@id/badgeStatusDetail"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnBackDetail"
            app:tint="#FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        android:translationY="-32dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavDetail"
        app:layout_constraintTop_toBottomOf="@id/fixedHeaderSection">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_top_white"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvDetailLokasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Gedung D, Lab Komputer 2"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:gravity="center_vertical"
                android:drawableStart="@drawable/ic_location"
                android:drawablePadding="8dp" />

            <TextView
                android:id="@+id/tvDetailDeskripsi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_modern"
                android:fontFamily="@font/inter_light"
                android:padding="20dp"
                android:text="&quot;AC di pojok kanan belakang meneteskan air dan udaranya tidak dingin sama sekali sejak pagi tadi.&quot;"
                android:textColor="#475569"
                android:textSize="12sp"
                android:lineHeight="20sp"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_rounded_blue_light"
                android:padding="16dp">

                <FrameLayout
                    android:id="@+id/iconTeknisi"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_blue_light"
                    android:backgroundTint="#2563EB"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_technician2"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <TextView
                    android:id="@+id/lblTeknisi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="DITANGANI OLEH"
                    android:textColor="#2563EB"
                    android:textSize="10sp"
                    app:layout_constraintStart_toEndOf="@id/iconTeknisi"
                    app:layout_constraintTop_toTopOf="@id/iconTeknisi" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:fontFamily="@font/inter_bold"
                    android:text="Bpk. Sumardi"
                    android:textColor="#0F172A"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/iconTeknisi"
                    app:layout_constraintStart_toEndOf="@id/iconTeknisi" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_rounded_top_white"
                    android:backgroundTint="#FFFFFF"
                    android:fontFamily="@font/inter_bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="★ 4.9"
                    android:textColor="#FBBF24"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="@font/inter_extrabold"
                android:letterSpacing="0.05"
                android:text="JEJAK PENYELESAIAN"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">
                        <FrameLayout
                            android:id="@+id/bgIconTimeline1"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_dark_transparent"
                            android:backgroundTint="#10B981">
                            <ImageView
                                android:id="@+id/ivIconTimeline1"
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_timeline" />
                        </FrameLayout>
                        <View
                            android:layout_width="2dp"
                            android:layout_height="match_parent"
                            android:layout_marginTop="4dp"
                            android:background="#CBD5E1" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingBottom="24dp">
                        <TextView
                            android:id="@+id/tvTitleTimeline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="Perbaikan Selesai"
                            android:textColor="#0F172A"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/tvDescTimeline1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_regular"
                            android:text="AC telah dicuci dan freon diisi ulang. Berfungsi normal."
                            android:textColor="#64748B"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/tvDateTimeline1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_bold"
                            android:text="16 Apr 2026, 14:00 WITA"
                            android:textColor="#10B981"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">
                        <FrameLayout
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:background="@drawable/bg_circle_dark_transparent"
                            android:backgroundTint="#CBD5E1">
                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_timeline"
                                app:tint="#94A3B8"/>
                        </FrameLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter_bold"
                            android:text="Laporan Terkirim"
                            android:textColor="#64748B"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="@font/inter_regular"
                            android:text="Laporan telah diterima oleh sistem aplikasi."
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/tvDateTimeline2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter_medium"
                            android:text="15 Apr 2026, 11:30 WITA"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_button_primary"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_star_rating" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_bold"
                android:text="Beri Penilaian Teknisi"
                android:textColor="#0F172A"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>