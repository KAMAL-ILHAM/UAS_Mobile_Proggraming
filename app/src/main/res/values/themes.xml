<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UTS" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

        <!-- TRICK SPLASH SCREEN: Mengubah background putih bawaan sistem menjadi biru milikmu -->
        <item name="android:windowSplashScreenBackground">#2563EB</item>
        <!-- TRICK SPLASH SCREEN: Menyembunyikan logo bawaan sistem agar layarnya polos biru -->
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>

    <style name="Theme.UTS" parent="Base.Theme.UTS" />

    <style name="Theme.UTS.Fullscreen" parent="Theme.UTS">
        <item name="android:actionBarStyle">@style/Widget.Theme.UTS.ActionBar.Fullscreen</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:windowBackground">@null</item>
    </style>

    <style name="ThemeOverlay.UTS.FullscreenContainer" parent="">
        <!-- Aku sekalian samakan warna background fullscreen ini dengan biru milikmu -->
        <item name="fullscreenBackgroundColor">#2563EB</item>
        <item name="fullscreenTextColor">@color/light_blue_A200</item>
    </style>
</resources>